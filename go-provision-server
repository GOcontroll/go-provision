#!/usr/bin/env python3
"""
go-provision-server — GOcontroll controller provisioning endpoint.
Listens on 0.0.0.0:8743, serves GET /info as JSON.
Only stdlib, no pip packages required.
"""

import http.server
import json
import os
import re
import socket
import subprocess


PORT = 8743

# Murata WiFi USB adapter identifiers (idVendor:idProduct)
WIFI_USB_IDS = {
    "04b4:6502": "1DX",
    "0846:9053": "1MW",
    "0bda:8179": "1YN",
}


def _run(cmd):
    """Run a shell command; return stripped stdout or None on failure."""
    try:
        out = subprocess.check_output(
            cmd, shell=True, text=True, stderr=subprocess.DEVNULL
        ).strip()
        return out or None
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def _hardware_version():
    try:
        with open("/sys/firmware/devicetree/base/hardware") as f:
            return f.read().rstrip("\x00").strip() or None
    except OSError:
        return _run("identify")


def _modules():
    """Return list of 8 slot dicts (or None for empty slots)."""
    results = [None] * 8

    # Slot names from go-modules scan
    names = {}
    scan = _run("go-modules scan")
    if scan:
        for line in scan.splitlines():
            m = re.match(r"slot\s+(\d+):\s+(.+?)(?:\s+version\s+.*)?$", line, re.IGNORECASE)
            if m:
                names[int(m.group(1))] = m.group(2).strip()

    # QR codes from firmware files
    fw_dir = "/lib/firmware/gocontroll/modules"
    for slot in range(1, 9):
        fw_file = os.path.join(fw_dir, f"slot{slot}")
        qr_front = qr_rear = None
        try:
            with open(fw_file) as f:
                lines = f.read().splitlines()
            # File format: line 0=fw_versions, 1=mfr_ids, 2=qr_front, 3=qr_rear
            qr_front = lines[2].strip() if len(lines) > 2 else None
            qr_rear  = lines[3].strip() if len(lines) > 3 else None
        except OSError:
            pass

        name = names.get(slot)
        if name or qr_front or qr_rear:
            results[slot - 1] = {
                "slot":      slot,
                "name":      name,
                "qr_front":  qr_front,
                "qr_rear":   qr_rear,
            }

    return results


def _modem():
    """Return modem/SIM info via mmcli, or None if no modem present."""
    modem_list = _run("mmcli -J --list-modems")
    if not modem_list:
        return None
    try:
        data   = json.loads(modem_list)
        modems = data.get("modem-list", [])
        if not modems:
            return None
        modem_num = modems[0].split("/")[-1]
        raw = _run(f"mmcli -J --modem={modem_num}")
        if not raw:
            return None
        md     = json.loads(raw)["modem"]
        serial = md.get("generic", {}).get("equipment-identifier") or None
        imei   = md.get("3gpp",    {}).get("imei")                 or None

        # SIM ICCID
        iccid    = None
        sim_path = md.get("generic", {}).get("sim")
        if sim_path:
            sim_num  = sim_path.split("/")[-1]
            sim_raw  = _run(f"mmcli -J --sim={sim_num}")
            if sim_raw:
                sd    = json.loads(sim_raw).get("sim", {})
                iccid = sd.get("properties", {}).get("iccid") or None

        return {"serial": serial, "sim_iccid": iccid, "imei": imei}
    except (json.JSONDecodeError, KeyError, TypeError):
        return None


def _wifi():
    """Detect Murata WiFi USB adapter model by USB ID, or None."""
    try:
        for entry in os.listdir("/sys/bus/usb/devices"):
            base = f"/sys/bus/usb/devices/{entry}"
            try:
                vid = open(f"{base}/idVendor").read().strip()
                pid = open(f"{base}/idProduct").read().strip()
                model = WIFI_USB_IDS.get(f"{vid}:{pid}")
                if model:
                    return {"model": model}
            except OSError:
                continue
    except OSError:
        pass
    return None


def _network():
    """Return (mac, ip, hostname) for the primary ethernet interface."""
    hostname = socket.gethostname()
    mac = ip = None

    try:
        for name in sorted(os.listdir("/sys/class/net")):
            if name in ("lo",) or name.startswith(("wlan", "wwan", "usb")):
                continue
            try:
                addr = open(f"/sys/class/net/{name}/address").read().strip()
                if addr and addr != "00:00:00:00:00:00":
                    mac  = addr
                    ip   = _run(
                        f"ip -4 addr show {name} | awk '/inet /{{print $2}}' | cut -d/ -f1"
                    )
                    break
            except OSError:
                continue
    except OSError:
        pass

    return mac, ip, hostname


def _serial():
    """Read controller serial number via go-sn."""
    return _run("go-sn read")


def build_info():
    mac, ip, hostname = _network()
    return {
        "mac":              mac,
        "ip":               ip,
        "hostname":         hostname,
        "serial":           _serial(),
        "hardware_version": _hardware_version(),
        "modules":          _modules(),
        "modem":            _modem(),
        "wifi":             _wifi(),
    }


class ProvisionHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/info":
            body = json.dumps(build_info(), indent=2).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_error(404)

    def log_message(self, fmt, *args):
        pass  # suppress request logs


if __name__ == "__main__":
    server = http.server.HTTPServer(("0.0.0.0", PORT), ProvisionHandler)
    server.serve_forever()
