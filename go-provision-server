#!/usr/bin/env python3
"""
go-provision-server — GOcontroll controller provisioning endpoint.
Listens on 0.0.0.0:8743, serves GET /info as JSON.
Only stdlib, no pip packages required.
"""

import http.server
import json
import os
import re
import socket
import subprocess
import time


PORT = 8743
# Modem-detectie verloopt in twee fasen na "systemctl start go-wwan":
#   1. USB-enumeratie van de SIM7600 duurt gemeten ~11 s. Als binnen
#      USB_PROBE_SECONDS geen non-roothub USB-device verschijnt, gaan we
#      ervan uit dat deze controller geen modem heeft en stoppen direct.
#   2. Na USB-enumeratie duurt het nog ~13 s voor ModemManager (mmcli) de
#      modem geregistreerd heeft. MODEM_AFTER_USB_SECONDS is de extra wachttijd
#      die we daarna geven voordat we opgeven.
USB_PROBE_SECONDS = 15
MODEM_AFTER_USB_SECONDS = 20
MODEM_POLL_INTERVAL = 1

VALID_SN_RE = re.compile(r"^[A-Za-z0-9]{4}-[A-Za-z0-9]{4}-[A-Za-z0-9]{4}-[A-Za-z0-9]{4}$")
POSTINSTALL_PATH = "/usr/local/sbin/postinstall.sh"
POSTINSTALL_LOG = "/var/log/go-provision-postinstall.log"
RUN_SCRIPT_PATH = "/tmp/go-provision-run.sh"
RUN_SCRIPT_LOG = "/var/log/go-provision-run.log"

# Murata WiFi USB adapter identifiers (idVendor:idProduct)
WIFI_USB_IDS = {
    "04b4:6502": "1DX",
    "0846:9053": "1MW",
}

# Murata WiFi SDIO identifiers (vendor:device as read from sysfs, lowercase 0x-prefixed)
# 0x02d0 is the Broadcom/Cypress SDIO vendor ID used in Murata Type 1xx modules.
WIFI_SDIO_IDS = {
    "0x02d0:0xa9a6": "1YN",  # CYW43439
}


def _run(cmd, timeout=10):
    """Run a shell command; return stripped stdout or None on failure."""
    try:
        out = subprocess.check_output(
            cmd, shell=True, text=True, stderr=subprocess.DEVNULL, timeout=timeout
        ).strip()
        return out or None
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return None


def _read_dtb(name):
    """Read a null-terminated dtb property."""
    try:
        with open(f"/sys/firmware/devicetree/base/{name}") as f:
            return f.read().rstrip("\x00").strip() or None
    except OSError:
        return None


def _platform():
    """Platform string from dtb, e.g. 'Moduline M1'."""
    return _read_dtb("platform")


def _hardware_version():
    """Hardware version from dtb 'hardware' field, e.g. 'Moduline Mini V1.11' → '1.11'."""
    raw = _read_dtb("hardware")
    if not raw:
        raw = _run("identify")
    if not raw:
        return None, None
    m = re.search(r"V?(\d+\.\d+(?:-[A-Za-z])?)", raw)
    return (m.group(1) if m else None), raw


def _software_version():
    """Kernel version as 'Linux 6.12.x' (major.minor.x format)."""
    raw = _run("uname -r")
    if not raw:
        return None
    m = re.match(r"(\d+\.\d+)\.", raw)
    if m:
        return f"Linux {m.group(1)}.x"
    return f"Linux {raw}"


def _max_slots_for_platform(platform):
    """Slot count per platform (from architecture: M1/M2=4, L4/L5/HMI1/HMI2=8)."""
    if platform and re.search(r"\bM\d+\b", platform):
        return 4
    return 8


def _modules(slot_count):
    """Run go-modules scan and parse /lib/firmware/gocontroll/modules.json."""
    _run("go-modules scan", timeout=20)
    try:
        with open("/lib/firmware/gocontroll/modules.json") as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError):
        return [{"slot": i + 1, "empty": True} for i in range(slot_count)]

    result = []
    by_slot = {s.get("slot"): s for s in data.get("slots", []) if isinstance(s, dict)}
    for n in range(1, slot_count + 1):
        s = by_slot.get(n)
        # Slot is leeg als er geen module_type EN geen firmware bekend is.
        # qr_front=0 (falsy) komt voor bij modules waarvan de QR nog niet in de
        # EEPROM is geprogrammeerd; die wel rapporteren met qr_front=null zodat
        # de DB-frontend ze aan een placeholder kan koppelen.
        if not s or (not s.get("module_type") and not s.get("firmware")):
            result.append({"slot": n, "empty": True})
            continue
        result.append({
            "slot":             n,
            "empty":            False,
            "qr_front":         s.get("qr_front") or None,
            "qr_back":          s.get("qr_back") or None,
            "module_type":      s.get("module_type") or None,
            "hardware_version": s.get("hardware_version") or None,
            "firmware":         s.get("firmware") or None,
            "manufacturer":     s.get("manufacturer") or None,
        })
    return result


def _modem_present():
    """True if mmcli sees at least one modem."""
    raw = _run("mmcli -J --list-modems")
    if not raw:
        return False
    try:
        data = json.loads(raw)
        return bool(data.get("modem-list"))
    except json.JSONDecodeError:
        return False


def _usb_modem_present():
    """True if a USB device other than a Linux Foundation root hub is enumerated."""
    raw = _run("lsusb")
    if not raw:
        return False
    for line in raw.splitlines():
        if "1d6b:" in line:  # Linux Foundation root hub
            continue
        if line.strip():
            return True
    return False


def _read_modem():
    """Read modem details via mmcli. Returns None on any failure."""
    raw = _run("mmcli -J --list-modems")
    if not raw:
        return None
    try:
        modems = json.loads(raw).get("modem-list", [])
        if not modems:
            return None
        modem_num = modems[0].split("/")[-1]
        md_raw = _run(f"mmcli -J --modem={modem_num}")
        if not md_raw:
            return None
        md = json.loads(md_raw)["modem"]
        serial = md.get("generic", {}).get("equipment-identifier") or None
        imei   = md.get("3gpp", {}).get("imei") or None

        iccid = None
        sim_path = md.get("generic", {}).get("sim")
        if sim_path:
            sim_num = sim_path.split("/")[-1]
            sim_raw = _run(f"mmcli -J --sim={sim_num}")
            if sim_raw:
                sd = json.loads(sim_raw).get("sim", {})
                iccid = sd.get("properties", {}).get("iccid") or None

        return {"detected": True, "serial": serial, "sim_iccid": iccid, "imei": imei}
    except (json.JSONDecodeError, KeyError, TypeError):
        return None


def _modem_flow():
    """
    Start go-wwan, then detect modem in twee fasen:
      Fase 1: poll lsusb tot USB_PROBE_SECONDS. Geen non-roothub USB-device
              binnen die tijd betekent dat deze controller geen modem heeft —
              direct return {detected: False} zodat /info niet onnodig blijft hangen.
      Fase 2: zodra USB-device verschijnt, poll mmcli tot MODEM_AFTER_USB_SECONDS
              extra. ModemManager heeft tijd nodig om de AT-poorten te probeen
              en de modem te registreren.
    """
    _run("systemctl start go-wwan.service", timeout=10)

    usb_deadline = time.monotonic() + USB_PROBE_SECONDS
    while time.monotonic() < usb_deadline:
        if _usb_modem_present():
            break
        time.sleep(MODEM_POLL_INTERVAL)
    else:
        return {"detected": False, "serial": None, "sim_iccid": None, "imei": None}

    register_deadline = time.monotonic() + MODEM_AFTER_USB_SECONDS
    while time.monotonic() < register_deadline:
        if _modem_present():
            info = _read_modem()
            if info:
                _run("systemctl enable go-wwan.service", timeout=10)
                return info
        time.sleep(MODEM_POLL_INTERVAL)
    return {"detected": False, "serial": None, "sim_iccid": None, "imei": None}


def _wifi():
    """Detect Murata WiFi module via SDIO (Moduline default) or USB adapter."""
    try:
        for entry in os.listdir("/sys/bus/sdio/devices"):
            base = f"/sys/bus/sdio/devices/{entry}"
            try:
                vid = open(f"{base}/vendor").read().strip()
                pid = open(f"{base}/device").read().strip()
                model = WIFI_SDIO_IDS.get(f"{vid}:{pid}")
                if model:
                    return {"model": model}
            except OSError:
                continue
    except OSError:
        pass
    try:
        for entry in os.listdir("/sys/bus/usb/devices"):
            base = f"/sys/bus/usb/devices/{entry}"
            try:
                vid = open(f"{base}/idVendor").read().strip()
                pid = open(f"{base}/idProduct").read().strip()
                model = WIFI_USB_IDS.get(f"{vid}:{pid}")
                if model:
                    return {"model": model}
            except OSError:
                continue
    except OSError:
        pass
    return None


def _network():
    """Return (mac, ip, hostname) for the primary ethernet interface."""
    hostname = socket.gethostname()
    mac = ip = None

    try:
        for name in sorted(os.listdir("/sys/class/net")):
            if name in ("lo",) or name.startswith(("wlan", "wwan", "usb")):
                continue
            try:
                addr = open(f"/sys/class/net/{name}/address").read().strip()
                if addr and addr != "00:00:00:00:00:00":
                    mac = addr
                    ip = _run(
                        f"ip -4 addr show {name} | awk '/inet /{{print $2}}' | cut -d/ -f1"
                    )
                    break
            except OSError:
                continue
    except OSError:
        pass

    return mac, ip, hostname


def _serial():
    """Read controller serial number via go-sn."""
    return _run("go-sn read")


# Services that can be enabled/disabled via /services. Must stay in sync with
# CTRL_SERVICES in GOcontroll-Database/index.js.
MANAGED_SERVICES = [
    "ssh",
    "go-simulink",
    "nodered",
    "go-bluetooth",
    "go-upload-server",
    "go-auto-shutdown",
    "gadget-getty@ttyGS0",
    "getty@ttymxc2",
    "go-web-ui",
    "go-wwan",
]


def _service_exists(name):
    """True if the unit file is known to systemd (list-unit-files contains a match)."""
    out = _run(f"systemctl list-unit-files --no-legend --no-pager '{name}.service'")
    if not out:
        return False
    return bool(out.strip())


def _service_enabled(name):
    """True if systemctl reports is-enabled in {enabled, enabled-runtime, static, alias, indirect}."""
    out = _run(f"systemctl is-enabled '{name}.service'")
    if out is None:
        return False
    return out.strip() in ("enabled", "enabled-runtime", "static", "alias", "indirect")


def _service_active(name):
    """True if systemctl is-active returns active."""
    out = _run(f"systemctl is-active '{name}.service'")
    if out is None:
        return False
    return out.strip() == "active"


def services_status():
    """Return list of {name, exists, enabled, active} for every managed service."""
    result = []
    for name in MANAGED_SERVICES:
        if not _service_exists(name):
            result.append({"name": name, "exists": False, "enabled": False, "active": False})
            continue
        result.append({
            "name":    name,
            "exists":  True,
            "enabled": _service_enabled(name),
            "active":  _service_active(name),
        })
    return result


def services_apply(desired):
    """
    Apply the desired enable/disable state per service.
    `desired` is a dict {service_name: bool}.
    Only services in MANAGED_SERVICES are touched; unknown names are ignored.
    Already-matching services are skipped (no-op) to keep changes minimal.
    Returns a list of per-service result dicts.
    """
    results = []
    if not isinstance(desired, dict):
        return results
    for name in MANAGED_SERVICES:
        if name not in desired:
            continue
        want_enabled = bool(desired[name])
        if not _service_exists(name):
            results.append({"name": name, "ok": False, "skipped": True, "error": "service niet aanwezig"})
            continue
        current_enabled = _service_enabled(name)
        current_active  = _service_active(name)
        if current_enabled == want_enabled and current_active == want_enabled:
            results.append({"name": name, "ok": True, "skipped": True, "enabled": want_enabled})
            continue
        verb_long  = "enable" if want_enabled else "disable"
        verb_state = "start"  if want_enabled else "stop"
        ok1, out1 = _run_args(["systemctl", verb_long,  f"{name}.service"])
        ok2, out2 = _run_args(["systemctl", verb_state, f"{name}.service"])
        if ok1 and ok2:
            results.append({"name": name, "ok": True, "skipped": False, "enabled": want_enabled})
        else:
            err = (out1 if not ok1 else out2) or "onbekend"
            results.append({"name": name, "ok": False, "skipped": False, "enabled": current_enabled, "error": err})
    return results


def _run_args(args, timeout=10):
    """Run a command as argv list; return (ok, output)."""
    try:
        out = subprocess.check_output(
            args, text=True, stderr=subprocess.STDOUT, timeout=timeout
        ).strip()
        return True, out
    except subprocess.CalledProcessError as e:
        return False, (e.output or "").strip() or str(e)
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return False, str(e)


def write_serial(sn):
    """Write SN via go-sn and read back to validate."""
    if not sn or not VALID_SN_RE.match(sn):
        return {"ok": False, "error": "ongeldig SN-formaat (verwacht 4x4-4-4-4 alfanumeriek)"}
    ok_w, out_w = _run_args(["go-sn", "w", sn])
    if not ok_w:
        return {"ok": False, "wrote": sn, "error": "go-sn write fout: " + out_w}
    time.sleep(0.3)
    ok_r, read_back = _run_args(["go-sn", "r"])
    if not ok_r:
        return {"ok": False, "wrote": sn, "error": "go-sn read fout: " + read_back}
    if read_back != sn:
        return {"ok": False, "wrote": sn, "read_back": read_back, "error": "read-back mismatch"}
    return {"ok": True, "wrote": sn, "read_back": read_back}


def start_postinstall():
    """Start postinstall.sh in background, log to file. Returns immediately."""
    try:
        log_f = open(POSTINSTALL_LOG, "ab")
        log_f.write(("\n=== %s start ===\n" % time.strftime("%Y-%m-%d %H:%M:%S")).encode())
        log_f.flush()
        subprocess.Popen(
            [POSTINSTALL_PATH],
            stdout=log_f, stderr=subprocess.STDOUT,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
        return {"started": True, "log": POSTINSTALL_LOG}
    except (OSError, FileNotFoundError) as e:
        return {"started": False, "error": str(e)}


def run_script(script_content):
    """Save script content to RUN_SCRIPT_PATH, exec via bash in background."""
    try:
        with open(RUN_SCRIPT_PATH, "w") as f:
            f.write(script_content)
        os.chmod(RUN_SCRIPT_PATH, 0o755)
        log_f = open(RUN_SCRIPT_LOG, "ab")
        log_f.write(("\n=== %s start ===\n" % time.strftime("%Y-%m-%d %H:%M:%S")).encode())
        log_f.flush()
        subprocess.Popen(
            ["/bin/bash", RUN_SCRIPT_PATH],
            stdout=log_f, stderr=subprocess.STDOUT,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
        return {"started": True, "log": RUN_SCRIPT_LOG, "size": len(script_content)}
    except (OSError, FileNotFoundError) as e:
        return {"started": False, "error": str(e)}


def build_info():
    mac, ip, hostname = _network()
    platform = _platform()
    hw_ver, hw_full = _hardware_version()
    return {
        "mac":              mac,
        "ip":               ip,
        "hostname":         hostname,
        "serial":           _serial(),
        "platform":         platform,
        "hardware_version": hw_ver,
        "hardware_full":    hw_full,
        "software_version": _software_version(),
        "modules":          _modules(_max_slots_for_platform(platform)),
        "modem":            _modem_flow(),
        "wifi":             _wifi(),
    }


class ProvisionHandler(http.server.BaseHTTPRequestHandler):
    def _respond(self, code, obj):
        body = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _read_json(self):
        try:
            n = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            n = 0
        raw = self.rfile.read(n) if n > 0 else b""
        if not raw:
            return {}
        try:
            return json.loads(raw)
        except (json.JSONDecodeError, ValueError):
            return None

    def do_GET(self):
        if self.path == "/info":
            body = json.dumps(build_info(), indent=2).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if self.path == "/services":
            self._respond(200, {"services": services_status()})
            return
        self.send_error(404)

    def do_POST(self):
        if self.path == "/sn":
            body = self._read_json()
            if body is None:
                self._respond(400, {"ok": False, "error": "invalid JSON"})
                return
            sn = (body.get("serial") or "").strip()
            result = write_serial(sn)
            self._respond(200 if result.get("ok") else 400, result)
            return
        if self.path == "/postinstall":
            result = start_postinstall()
            self._respond(202 if result.get("started") else 500, result)
            return
        if self.path == "/run-script":
            body = self._read_json()
            if body is None:
                self._respond(400, {"started": False, "error": "invalid JSON"})
                return
            script = body.get("script") or ""
            if not script.strip():
                self._respond(400, {"started": False, "error": "leeg script"})
                return
            result = run_script(script)
            self._respond(202 if result.get("started") else 500, result)
            return
        if self.path == "/services":
            body = self._read_json()
            if body is None:
                self._respond(400, {"ok": False, "error": "invalid JSON"})
                return
            desired = body.get("desired") if isinstance(body, dict) else None
            if not isinstance(desired, dict):
                self._respond(400, {"ok": False, "error": "verwacht: {\"desired\": {service: bool, ...}}"})
                return
            results = services_apply(desired)
            self._respond(200, {"results": results})
            return
        self.send_error(404)

    def log_message(self, fmt, *args):
        pass  # suppress request logs


if __name__ == "__main__":
    server = http.server.HTTPServer(("0.0.0.0", PORT), ProvisionHandler)
    server.serve_forever()
