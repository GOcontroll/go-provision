#!/usr/bin/env python3
"""
go-provision-server — GOcontroll controller provisioning endpoint.
Listens on 0.0.0.0:8743, serves GET /info as JSON.
Only stdlib, no pip packages required.
"""

import http.server
import json
import os
import re
import socket
import subprocess
import time


PORT = 8743
MODEM_WAIT_SECONDS = 30
MODEM_POLL_INTERVAL = 3

# Murata WiFi USB adapter identifiers (idVendor:idProduct)
WIFI_USB_IDS = {
    "04b4:6502": "1DX",
    "0846:9053": "1MW",
    "0bda:8179": "1YN",
}


def _run(cmd, timeout=10):
    """Run a shell command; return stripped stdout or None on failure."""
    try:
        out = subprocess.check_output(
            cmd, shell=True, text=True, stderr=subprocess.DEVNULL, timeout=timeout
        ).strip()
        return out or None
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return None


def _read_dtb(name):
    """Read a null-terminated dtb property."""
    try:
        with open(f"/sys/firmware/devicetree/base/{name}") as f:
            return f.read().rstrip("\x00").strip() or None
    except OSError:
        return None


def _platform():
    """Platform string from dtb, e.g. 'Moduline M1'."""
    return _read_dtb("platform")


def _hardware_version():
    """Hardware version from dtb 'hardware' field, e.g. 'Moduline Mini V1.11' → '1.11'."""
    raw = _read_dtb("hardware")
    if not raw:
        raw = _run("identify")
    if not raw:
        return None, None
    m = re.search(r"V?(\d+\.\d+(?:-[A-Za-z])?)", raw)
    return (m.group(1) if m else None), raw


def _software_version():
    """Kernel version as 'Linux 6.12.x' (major.minor.x format)."""
    raw = _run("uname -r")
    if not raw:
        return None
    m = re.match(r"(\d+\.\d+)\.", raw)
    if m:
        return f"Linux {m.group(1)}.x"
    return f"Linux {raw}"


def _max_slots_for_platform(platform):
    """Slot count per platform (from architecture: M1/M2=4, L4/L5/HMI1/HMI2=8)."""
    if platform and re.search(r"\bM\d+\b", platform):
        return 4
    return 8


def _modules(slot_count):
    """Run go-modules scan and parse /lib/firmware/gocontroll/modules.json."""
    _run("go-modules scan", timeout=20)
    try:
        with open("/lib/firmware/gocontroll/modules.json") as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError):
        return [{"slot": i + 1, "empty": True} for i in range(slot_count)]

    result = []
    by_slot = {s.get("slot"): s for s in data.get("slots", []) if isinstance(s, dict)}
    for n in range(1, slot_count + 1):
        s = by_slot.get(n)
        if not s or not s.get("qr_front"):
            result.append({"slot": n, "empty": True})
            continue
        result.append({
            "slot":         n,
            "empty":        False,
            "qr_front":     s.get("qr_front") or None,
            "qr_back":      s.get("qr_back") or None,
            "module_type":  s.get("module_type") or None,
            "firmware":     s.get("firmware") or None,
            "manufacturer": s.get("manufacturer") or None,
        })
    return result


def _modem_present():
    """True if mmcli sees at least one modem."""
    raw = _run("mmcli -J --list-modems")
    if not raw:
        return False
    try:
        data = json.loads(raw)
        return bool(data.get("modem-list"))
    except json.JSONDecodeError:
        return False


def _read_modem():
    """Read modem details via mmcli. Returns None on any failure."""
    raw = _run("mmcli -J --list-modems")
    if not raw:
        return None
    try:
        modems = json.loads(raw).get("modem-list", [])
        if not modems:
            return None
        modem_num = modems[0].split("/")[-1]
        md_raw = _run(f"mmcli -J --modem={modem_num}")
        if not md_raw:
            return None
        md = json.loads(md_raw)["modem"]
        serial = md.get("generic", {}).get("equipment-identifier") or None
        imei   = md.get("3gpp", {}).get("imei") or None

        iccid = None
        sim_path = md.get("generic", {}).get("sim")
        if sim_path:
            sim_num = sim_path.split("/")[-1]
            sim_raw = _run(f"mmcli -J --sim={sim_num}")
            if sim_raw:
                sd = json.loads(sim_raw).get("sim", {})
                iccid = sd.get("properties", {}).get("iccid") or None

        return {"detected": True, "serial": serial, "sim_iccid": iccid, "imei": imei}
    except (json.JSONDecodeError, KeyError, TypeError):
        return None


def _modem_flow():
    """
    Start go-wwan, poll up to MODEM_WAIT_SECONDS. If modem appears, enable
    go-wwan for persistence and return its details. Otherwise return
    {'detected': False}.
    """
    _run("systemctl start go-wwan.service", timeout=10)
    deadline = time.monotonic() + MODEM_WAIT_SECONDS
    while time.monotonic() < deadline:
        if _modem_present():
            info = _read_modem()
            if info:
                _run("systemctl enable go-wwan.service", timeout=10)
                return info
        time.sleep(MODEM_POLL_INTERVAL)
    return {"detected": False, "serial": None, "sim_iccid": None, "imei": None}


def _wifi():
    """Detect Murata WiFi USB adapter model by USB ID, or None."""
    try:
        for entry in os.listdir("/sys/bus/usb/devices"):
            base = f"/sys/bus/usb/devices/{entry}"
            try:
                vid = open(f"{base}/idVendor").read().strip()
                pid = open(f"{base}/idProduct").read().strip()
                model = WIFI_USB_IDS.get(f"{vid}:{pid}")
                if model:
                    return {"model": model}
            except OSError:
                continue
    except OSError:
        pass
    return None


def _network():
    """Return (mac, ip, hostname) for the primary ethernet interface."""
    hostname = socket.gethostname()
    mac = ip = None

    try:
        for name in sorted(os.listdir("/sys/class/net")):
            if name in ("lo",) or name.startswith(("wlan", "wwan", "usb")):
                continue
            try:
                addr = open(f"/sys/class/net/{name}/address").read().strip()
                if addr and addr != "00:00:00:00:00:00":
                    mac = addr
                    ip = _run(
                        f"ip -4 addr show {name} | awk '/inet /{{print $2}}' | cut -d/ -f1"
                    )
                    break
            except OSError:
                continue
    except OSError:
        pass

    return mac, ip, hostname


def _serial():
    """Read controller serial number via go-sn."""
    return _run("go-sn read")


def build_info():
    mac, ip, hostname = _network()
    platform = _platform()
    hw_ver, hw_full = _hardware_version()
    return {
        "mac":              mac,
        "ip":               ip,
        "hostname":         hostname,
        "serial":           _serial(),
        "platform":         platform,
        "hardware_version": hw_ver,
        "hardware_full":    hw_full,
        "software_version": _software_version(),
        "modules":          _modules(_max_slots_for_platform(platform)),
        "modem":            _modem_flow(),
        "wifi":             _wifi(),
    }


class ProvisionHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/info":
            body = json.dumps(build_info(), indent=2).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_error(404)

    def log_message(self, fmt, *args):
        pass  # suppress request logs


if __name__ == "__main__":
    server = http.server.HTTPServer(("0.0.0.0", PORT), ProvisionHandler)
    server.serve_forever()
